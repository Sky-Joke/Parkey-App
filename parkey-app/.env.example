# WalletConnect Cloud project ID (https://cloud.reown.com)
REACT_APP_WC_PROJECT_ID=your_walletconnect_project_id

# Chain par defaut : 11155111 = Sepolia, 31337 = Hardhat local
REACT_APP_CHAIN_ID=11155111

# Optionnel : override de l'adresse du contrat (sinon pris dans ParkeyNFT.json)
# REACT_APP_CONTRACT_ADDRESS=0x...
